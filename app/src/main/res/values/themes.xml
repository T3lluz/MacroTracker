<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DailyDash" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#080D18</item>
        <item name="android:statusBarColor">#080D18</item>
        <item name="android:navigationBarColor">#080D18</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme shown during cold start before Compose is ready -->
    <style name="Theme.DailyDash.Splash" parent="Theme.DailyDash">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>

