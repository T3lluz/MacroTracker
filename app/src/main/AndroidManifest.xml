<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <!-- Needed for AccountManager account picker to list Google accounts -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />
    <!-- Android 13+ post-notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />


    <!-- Allow discovery of Health Connect on Android 11+ -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".DailyDashApp"
        android:label="DailyDash"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.DailyDash">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.DailyDash.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Declare Health Connect data types we read -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Required activity-alias so Health Connect can resolve the permission request -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- DailyDash Home-Screen Widget — Full Dashboard -->
        <receiver
            android:name=".widget.DashboardWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dashboard_widget_info" />
        </receiver>

        <!-- DailyDash Widget — Macros & Nutrition -->
        <receiver
            android:name=".widget.MacrosWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_macros_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/macros_widget_info" />
        </receiver>

        <!-- DailyDash Widget — Health & Activity -->
        <receiver
            android:name=".widget.HealthWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_health_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/health_widget_info" />
        </receiver>

        <!-- DailyDash Widget — Weather -->
        <receiver
            android:name=".widget.WeatherWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_weather_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/weather_widget_info" />
        </receiver>

        <!-- DailyDash Widget — Calendar -->
        <receiver
            android:name=".widget.CalendarWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_calendar_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calendar_widget_info" />
        </receiver>

        <!-- F1 Widget — Next Race Countdown -->
        <receiver
            android:name=".widget.F1CountdownWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_f1_countdown_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/f1_countdown_widget_info" />
        </receiver>

        <!-- F1 Widget — Championship Standings -->
        <receiver
            android:name=".widget.F1StandingsWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_f1_standings_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/f1_standings_widget_info" />
        </receiver>

        <!-- F1 Widget — Race Schedule -->
        <receiver
            android:name=".widget.F1ScheduleWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_f1_schedule_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/f1_schedule_widget_info" />
        </receiver>

    </application>

</manifest>